# Godot 4 — https://docs.godotengine.org
# Godot re-imports this on open; never commit it.
.godot/

# Exported builds (the Web build lands here; regenerated by the export step).
export/

# Editor / OS cruft and local secrets.
*.tmp
.env
.DS_Store

# Vercel CLI's local link (org/project IDs + cache) from `vercel link`/`vercel
# dev` — not secret on its own, but it's machine-local state, not project
# source; keeping it out avoids an untracked-file pull conflict later.
.vercel/

# Python bytecode from tools/
__pycache__/
*.pyc

# Local generated artifacts: visual-review snapshots (uploaded by CI per push)
# and worldgen candidate maps/galleries (deterministic — same brief + seed
# regenerates them byte-identically). Neither belongs in source history.
artifacts/

# Raw downloaded asset zips — keep the EXTRACTED art in git, not the archives.
# (Your backup copies stay on disk; git just ignores them.)
**/All Zip Files/
*.zip

# macOS archive junk (bit us on the duck download).
__MACOSX/
._*

# Aseprite source files — large, not needed by the game build.
*.aseprite

# Orphaned old placeholder art (replaced by the real Cute Fantasy pack).
assets/placeholder/

.vercel
.env*

# launcher: cached local Godot exe path (per-machine)
launcher/.godot-path
