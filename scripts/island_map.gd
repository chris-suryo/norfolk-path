class_name IslandMap
extends RefCounted

## The island level as an ASCII map — the single source of truth for layout.
##
## Edit this string to redesign the level; terrain, props, and entity spawn
## points all derive from it (level.gd paints terrain, main.gd places props
## and entities). Lives in a .gd const rather than a .txt because the Web
## export packs only Godot resources — a text file would silently vanish
## from browser builds.
##
## Legend:
##   ~  water (impassable)          .  grass
##   #  path                        S  spawn point (on path; P2 beside P1)
##   B  bridge (walkable water — bridge sprite drawn on top)
##   T  big oak tree (collides)     t  small oak (collides)
##   F  fence segment (collides)    H  Evan's shop (anchor = house base/door)
##   C  chicken (Ariana stand-in — should become a duck)
##
## Design rules the art imposes (edge sheets have no strip tiles):
##   - keep water and path regions at least 2 tiles wide
##   - avoid diagonal-only pinches; the preview renderer catches violations

const TILE_SIZE := 16

const MAP := """
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~....~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
~~~~~~~~~~~~~~~~~~~~~~~......~~~~..........~~~~~~~~~~~~~~~~~~~~~~~~~~~
~~~~~~~~~~~~~~~~~~~~t.................t.............~~~~~~~~~~~~~~~~~~
~~~~~~~~~~~~~~..T................T..................T..~~~~~~~~~~~~~~~
~~~~~~~~~~~~................................t...............~~~~~~~~~~
~~~~~~~~~~~.T...................................T............~~~~~~~~~
~~~~~~~~~~.........F..........F.....T....................T....~~~~~~~~
~~~~~~~~~..........F..........F................................~~~~~~~
~~~~~~~~...........F..........F................................~~~~~~~
~~~~~~~~.t.........F..........F........................t........~~~~~~
~~~~~~~............F..........F.................................~~~~~~
~~~~~~.............F....H.....F..................................~~~~~
~~~~~..............FFFF.##.FFFF........................~~~~~~~...~~~~~
~~~~....................##...........................~~~~~~~~~~~..~~~~
~~~.........t...........##.........................~~~~~~~~~~~~~~~.~~~
~~~.....................##........................~~~~~~~~~~~~~~~~~~~~
~~~.....................##........................~~~~~~~~~~~~~~~~~~~~
~~~.....#S##############################BB##########~~~~~~~~~~~~~~~~~~
~~~.....################################BB##########~~~~~~~~~~~~~~~~~~
~~~.....................................~~.......~~~~~~~~~~~~~~~~~~~~~
~~~.....................................~~.......~~~~~~~~~~~~~~~~~~~~~
~~~.....................................~~....C.~~~~~~~~~~~~~~~~~~~~~~
~~~....t................................~~......~~~~~~~~~~~~~~~~~~~~~~
~~~.....................................~~......~~~~~~~~~~~~~~~~~~~~~~
~~~...........................T.........~~.......~~~~~~~~~~~~~~~~~~~~~
~~~~.............t......................~~.......~~~~~~~~~~~~~~~..~~~~
~~~~~...................................~~.........~~~~~~~~~~~...~~~~~
~~~~~~....T.......................T.....~~.......................~~~~~
~~~~~~~.............T.......t...........~~.......t..............~~~~~~
~~~~~~~.................................~~......................~~~~~~
~~~~~~~.......T.........................~~...T..................~~~~~~
~~~~~~~..................T..............~~......................~~~~~~
~~~~~~~~................................~~......................~~~~~~
~~~~~~~~~...............................~~.....................~~~~~~~
~~~~~~~~~~~.............................~~....................~~~~~~~~
~~~~~~~~~~~~~...........................~~..................~~~~~~~~~~
~~~~~~~~~~~~~~~.........................~~...........~~~~~~~~~~~~~~~~~
~~~~~~~~~~~~~~~~~~~~....................~~.........~~~~~~~~~~~~~~~~~~~
~~~~~~~~~~~~~~~~~~~~~~~......~~~~~......~~.~~~~~~~~~~~~~~~~~~~~~~~~~~~
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~....~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
"""


static func rows() -> PackedStringArray:
	return MAP.strip_edges().split("\n")


## World-space center of a map cell.
static func cell_center(cell: Vector2i) -> Vector2:
	return Vector2(cell) * TILE_SIZE + Vector2(TILE_SIZE, TILE_SIZE) / 2.0


## All cells carrying the given symbol.
static func find_all(symbol: String) -> Array[Vector2i]:
	var found: Array[Vector2i] = []
	var lines := rows()
	for y in lines.size():
		var row := lines[y]
		for x in row.length():
			if row[x] == symbol:
				found.append(Vector2i(x, y))
	return found


## The single cell carrying the given symbol; pushes an error if absent.
static func find_one(symbol: String) -> Vector2i:
	var found := find_all(symbol)
	if found.is_empty():
		push_error("IslandMap: no '%s' symbol in MAP." % symbol)
		return Vector2i.ZERO
	return found[0]
