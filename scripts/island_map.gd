static func rows() -> PackedStringArray:
	return MAP.strip_edges().split("\n")


## World-space center of a map cell.
static func cell_center(cell: Vector2i) -> Vector2:
	return Vector2(cell) * TILE_SIZE + Vector2(TILE_SIZE, TILE_SIZE) / 2.0


## All cells carrying the given symbol.
static func find_all(symbol: String) -> Array[Vector2i]:
	var found: Array[Vector2i] = []
	var lines := rows()
	for y in lines.size():
		var row := lines[y]
		for x in row.length():
			if row[x] == symbol:
				found.append(Vector2i(x, y))
	return found


## The single cell carrying the given symbol; pushes an error if absent.
static func find_one(symbol: String) -> Vector2i:
	var found := find_all(symbol)
	if found.is_empty():
		push_error("IslandMap: no '%s' symbol in MAP." % symbol)
		return Vector2i.ZERO
	return found[0]
